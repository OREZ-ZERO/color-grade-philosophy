  "style_philosophy": {
    "emotional_goal": "Make open countryside feel calm, approachable, and sunlit, like a clean travel postcard rather than a dramatic landscape.",
    "contrast_strategy": "Lift the image into high-key daylight, keep shadows soft, and avoid heavy atmospheric drama.",
    "color_strategy": "Favor yellow-green land, pale cyan sky, light grey-blue mountains, and small warm animal or human accents.",
    "subject_strategy": "Treat people, animals, fences, houses, and roads as small anchors inside a wide pastoral field; do not over-emphasize them with contrast.",
    "texture_strategy": "Clean but not sterile; moderate detail, low grain, and gentle haze in distance.",
    "do_not_literalize": "Do not apply this to scenes that need mystery or depth. The style is open-air pastoral clarity, not generic brightness."
  },
  "semantic_transfer_rules": {
    "sky": "Pale cyan-blue, bright but not saturated cobalt.",
    "water": "Light cyan with calm reflections; keep pastoral softness.",
    "grass": "Yellow-green or straw-green under sun; avoid emerald/neon intensity.",
    "forest": "Soft blue-green distance, lower contrast than foreground fields.",
    "mountain": "Pale grey-blue with gentle haze; reduce harsh rock contrast.",
    "skin": "Small warm natural accents if people are present; avoid beauty-retouch warmth.",
    "white_clothing": "Clean daylight white with slight warmth, not clipped.",
    "shadow": "Soft green/blue shadows with lifted black point.",
    "highlight": "High-key sunlight, broad and clean, but retain cloud/grass texture."
  },
