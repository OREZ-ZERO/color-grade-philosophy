    ],
    "requires": {
      "has_shadow_structure": true,
      "has_warm_light_source_or_can_believably_receive_one": true,
      "benefits_from_emotional_pressure": true,
      "needs_close_subject": "face, hand, body detail, or intimate object"
    },
    "risks": [
      "skin becoming jaundiced",
      "crushed eyes or facial detail",
      "false amber cast on landscapes",
      "turning a clean image into an unintended horror/noir mood"
    ]
  },
