  "style_philosophy": {
    "emotional_goal": "Create compressed intimacy: the viewer feels close to the subject, with warm light pressing against darkness.",
    "contrast_strategy": "Use extreme tonal separation: deep brown-black background and a narrow warm highlight zone on skin.",
    "color_strategy": "Restrict the palette to amber, ochre, red-brown, and black; remove competing cool colors.",
    "subject_strategy": "The face is the only emotional light source. Preserve eyes, lips, and skin contour even when shadows become heavy.",
    "texture_strategy": "Visible film grain and imperfect softness are part of the feeling; avoid clean glossy retouching.",
    "do_not_literalize": "Do not pour amber over every target. This look needs a believable warm light source and surrounding darkness."
  },
  "semantic_transfer_rules": {
    "sky": "Generally not suitable. If present, suppress importance or use inspired-only warmth near the subject.",
    "water": "Usually avoid; amber water will look false unless it is night/reflection light.",
    "grass": "Not a direct target; keep dark olive/brown only if the scene is already low-key.",
    "forest": "Can become deep brown-black atmospheric shadow if a portrait subject is present.",
    "mountain": "Use inspired-only warm-shadow contrast; avoid full amber conversion.",
    "skin": "Warm amber/golden but not clipped or waxy; keep facial detail.",
    "white_clothing": "Cream or tobacco-stained white under warm light, not neutral white.",
    "shadow": "Deep brown-black with minimal but intentional detail.",
    "highlight": "Narrow amber/yellow highlight with strong rolloff; avoid broad flat exposure."
  },
  "compatibility": {
    "best_for": [
      "close low-key portraits",
