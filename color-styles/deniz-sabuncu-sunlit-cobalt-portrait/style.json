  "style_philosophy": {
    "emotional_goal": "Make the frame feel bright, direct, and graphic, with a single dominant environmental color carrying most of the visual energy.",
    "contrast_strategy": "Use clear daylight separation and strong color contrast rather than heavy filmic shadow crush; highlights stay clean and open.",
    "color_strategy": "Let a saturated cobalt/cyan-blue field dominate the environment, then stabilize the subject with warm beige, tan, and peach tones.",
    "subject_strategy": "Protect skin, hair, hats, and light clothing from becoming too blue; they should remain warm-neutral anchors against the blue field.",
    "texture_strategy": "Keep the image clean and sharp with very low grain; the effect is more graphic daylight than nostalgic film.",
    "do_not_literalize": "Do not turn every target background blue. Reserve cobalt for skies, painted walls, water, or negative spaces that can plausibly carry blue."
  },
  "semantic_transfer_rules": {
    "sky": "Can become the strongest saturated cobalt/cyan-blue area if the scene is sunny and graphic.",
    "water": "Can receive a clean cyan-blue treatment, but keep natural reflections and avoid neon.",
    "grass": "Preserve green identity; reduce saturation slightly if needed so the sky or negative space remains the main color field.",
    "forest": "Keep as dark green/blue-green support, not pure cobalt.",
    "mountain": "Cool toward clear blue-grey only when the scene already has strong daylight haze.",
    "skin": "Preserve warm peach or light tan; avoid cyan cast.",
    "white_clothing": "Render as warm linen/off-white with open highlights, not sterile blue-white.",
    "shadow": "Keep shadows clean and readable, slightly cool but not crushed.",
    "highlight": "Bright, dry, and sunlit; avoid creamy haze unless the target already has it."
  },
