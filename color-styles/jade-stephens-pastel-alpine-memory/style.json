  "style_philosophy": {
    "emotional_goal": "Make the landscape feel remembered rather than merely recorded: open, airy, slightly idealized, and gently sun-faded.",
    "contrast_strategy": "Compress harsh contrast, keep highlights soft and high, and allow shadows to stay colored rather than heavy.",
    "color_strategy": "Use pastel cyan sky, yellow-olive grass, soft warm whites, and blue/lavender atmospheric mountain distance.",
    "subject_strategy": "Small human-made details such as fabric, fences, huts, or path lines can become warm memory anchors, while the land stays broad and calm.",
    "texture_strategy": "Mild film grain and airy softness; avoid modern HDR clarity.",
    "do_not_literalize": "Do not paste the exact alpine palette onto incompatible subjects. Translate the memory logic into the target scene's own sky, land, distance, and highlight anchors."
  },
  "semantic_transfer_rules": {
    "sky": "Pastel cyan or pale blue with soft cloud whites; avoid deep saturated cobalt.",
    "water": "Pale blue/cyan with low contrast, treated like atmospheric distance.",
    "grass": "Muted yellow-green or olive meadow; preserve green identity but remove digital vibrancy.",
    "forest": "Deep green-blue support with softened contrast, never pure black.",
    "mountain": "Cool blue-grey or lavender-grey distance; keep rock texture but reduce harshness.",
    "skin": "If people are present, keep subtle warm peach and low saturation.",
    "white_clothing": "Warm sun-faded white or cream, with gentle rolloff.",
    "shadow": "Colored blue/green shadows with detail retained.",
    "highlight": "Soft, slightly warm, and nostalgic; avoid clipping."
  },
