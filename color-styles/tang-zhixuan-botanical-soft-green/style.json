  "style_philosophy": {
    "emotional_goal": "Let foliage become an intimate envelope around the person, making the portrait feel hidden, tender, and close to summer air.",
    "contrast_strategy": "Use medium contrast with leaf-shaped shadow structure; avoid hard black and avoid clinical brightness.",
    "color_strategy": "Build the image around layered greens: yellow-green highlights, emerald midtones, and deep olive shadows, while keeping skin creamy and slightly warm.",
    "subject_strategy": "The human face and light clothing should remain the soft brightness center; greens may surround the subject but should not contaminate skin.",
    "texture_strategy": "Soft natural detail, mild grain, and a gentle bloom around bright skin/fabric rather than high digital sharpness.",
    "do_not_literalize": "Do not apply green globally. The philosophy is botanical enclosure plus protected skin, not a green color wash."
  },
  "semantic_transfer_rules": {
    "sky": "Usually reduce sky importance; if visible, keep it pale and secondary.",
    "water": "Cool subtly if present, but do not compete with foliage.",
    "grass": "Lush soft green with moderate saturation; avoid neon lawn color.",
    "forest": "Layered emerald/olive depth with visible texture and filtered light.",
    "mountain": "Keep natural and understated; do not force green onto rocks.",
    "skin": "Creamy warm skin, protected from green cast; local corrections may be needed around face and hands.",
    "white_clothing": "Warm ivory or milk-white with soft highlight rolloff.",
    "shadow": "Green-brown or olive, soft-edged, not black.",
    "highlight": "Diffused leaf-filtered highlights; avoid clipped specular whites."
  },
