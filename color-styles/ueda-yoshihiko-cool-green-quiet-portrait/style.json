  "style_philosophy": {
    "emotional_goal": "Create quiet psychological distance: the subject feels present but inward, held by cool air and soft natural light.",
    "contrast_strategy": "Keep contrast restrained with open shadows and diffused highlights; avoid dramatic black/white separation.",
    "color_strategy": "Lower overall saturation and let cool greens, blue-greys, and faint mauves shape the atmosphere.",
    "subject_strategy": "Skin should be pale and believable with a small pink/peach trace; do not glamorize or over-warm the face.",
    "texture_strategy": "Soft film-like detail, mild grain, and gentle blur; the image should breathe rather than snap.",
    "do_not_literalize": "Do not simply desaturate everything. Preserve subtle skin life and local color relationships while reducing emotional loudness."
  },
  "semantic_transfer_rules": {
    "sky": "Pale blue-grey or soft cyan, low saturation.",
    "water": "Muted cool blue/green with gentle contrast.",
    "grass": "Ash-green or cool olive, never vivid lawn green.",
    "forest": "Layered deep green-grey with open shadows.",
    "mountain": "Cool grey-green or blue-grey, softened by atmosphere.",
    "skin": "Pale natural skin with slight pink/peach; protect from sickly green/cyan cast.",
    "white_clothing": "Soft off-white with cool air, not clipped and not pure grey.",
    "shadow": "Open cool green/blue shadow with detail retained.",
    "highlight": "Diffused, soft, and low-glare; avoid glossy commercial highlights."
  },
